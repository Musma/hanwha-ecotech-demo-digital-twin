{
  "name": "digital-twin-service",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "lint": "eslint \"**/*.{ts,vue}\" --fix",
    "lint:staged": "lint-staged",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "4"
  },
  "devDependencies": {
    "@musma/eslint-config-vue": "^1.0.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": "eslint --fix",
    "*.{css,scss,html,json,md,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.1.2"
}
